{
  "name": "orz-mdhtml",
  "version": "0.9.3",
  "description": "Generate single-file, self-editing .md.html documents from Markdown with live preview, source-aware copy, and in-place save.",
  "type": "module",
  "main": "./dist/lib.js",
  "types": "./dist/lib.d.ts",
  "exports": {
    ".": {
      "types": "./dist/lib.d.ts",
      "default": "./dist/lib.js"
    }
  },
  "bin": {
    "orz-mdhtml": "dist/cli.js"
  },
  "files": [
    "dist",
    "assets",
    "orz-mdhtml-skills",
    "PROTOCOL.md"
  ],
  "scripts": {
    "build": "tsc && npm run bundle",
    "bundle": "tsx build/bundle.ts",
    "gen": "tsx src/cli.ts",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "markdown",
    "orz-markdown",
    "self-contained",
    "html",
    "editor",
    "single-file"
  ],
  "author": "Yu Wang <yuwang@orz.how>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wangyu16/orz-mdhtml.git"
  },
  "homepage": "https://markdown.orz.how/family.html#mdhtml",
  "bugs": "https://github.com/wangyu16/orz-mdhtml/issues",
  "dependencies": {
    "orz-markdown": "^1.6.3"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "esbuild": "^0.28.1",
    "path-browserify": "^1.0.1",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
